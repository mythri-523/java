import java.util.Scanner;
public class Main {
public static void main(String[] args) {
Scanner sc = new Scanner(System.in);
int T = sc.nextInt();   
for (int i = 0; i < T; i++) {
int N = sc.nextInt();  
int X = sc.nextInt();  
int totalSlices = N * X;   
int pizzas;
if (totalSlices % 4 == 0) {
pizzas = totalSlices / 4;
} else {
pizzas = (totalSlices / 4) + 1;
            }
System.out.println(pizzas);
        }
    }
}
